# Version control
.git
.gitignore

# Python artifacts
__pycache__
*.py[cod]
*.pyo
*.pyd
*.egg-info
.eggs
dist
build

# Virtual environments — never copy these into the image
venv/
.venv/
env/

# Secrets — never bake these into the image
.env
.env.*
!.env.example

# Test infrastructure
tests/
app/tests/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Type checker and linter caches
.mypy_cache/
.ruff_cache/

# Editor and OS noise
.DS_Store
*.log
